# Presto Cockpit configuration — copy to `.env`, fill in, then run ./gen-secrets.sh
# (gen-secrets.sh parses this and writes secrets.json, which deploy.sh pushes to the device).
# Quote anything with spaces or shell metacharacters. UTF-8 is fine (emoji SSIDs work).
#
# Placeholders:
#   GPU_HOST     = box running the dgx-vitals sidecar (and vLLM/ASR/TTS), e.g. 10.0.0.10
#   GATEWAY_HOST = box running the openclaw-shim, e.g. 10.0.0.20  (may be the same box)

# --- WiFi (the Presto joins this network on boot) ---
WIFI_SSID="YOUR_WIFI_SSID"
WIFI_PASSWORD="YOUR_WIFI_PASSWORD"
WIFI_COUNTRY="US"

# --- GPU box telemetry (the dgx-vitals sidecar — see dgx-vitals/) ---
DGX_URL="http://GPU_HOST:9876/vitals"
DGX_POLL_S=1.0

# --- OpenClaw agents (via the LAN shim — see openclaw-shim/) ---
OPENCLAW_URL="http://GATEWAY_HOST:9787/agents"
OPENCLAW_BEARER=""            # optional; the shim is LAN/firewall-scoped. Set only if you front it with auth.
OPENCLAW_POLL_S=2.0

# --- Crypto ticker (CoinGecko public API, no key needed) ---
CRYPTO_IDS="bitcoin,ethereum,monero,solana"
CRYPTO_VS="usd"
CRYPTO_POLL_S=30

# --- Sensors / lights ---
SEA_LEVEL_HPA=1013.25         # local sea-level pressure (hPa) for the altitude screen
LED_BRIGHTNESS=0.6            # 0.0–1.0, the 7 rear RGB LEDs
LED_AUTO_DIM=true             # auto-dim the LEDs from the ambient-light sensor

# --- Optional: deploy the dgx-vitals sidecar over SSH ---
DGX_SSH="youruser@GPU_HOST"
